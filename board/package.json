{
  "name": "conductor-board",
  "version": "3.3.5",
  "description": "A portable spec and live Kanban board for orchestrating AI agent workflows.",
  "license": "MIT",
  "author": "mettafive",
  "type": "module",
  "bin": {
    "3042": "bin/cli.js",
    "conductor-board": "bin/cli.js"
  },
  "files": [
    "bin",
    "cli",
    "server",
    "dist"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "start": "node bin/cli.js",
    "simulate": "node scripts/simulate.js",
    "test:loops": "npx --yes tsx test/loops.smoke.ts",
    "test:artifacts": "node test/artifacts.smoke.mjs",
    "test:features": "node test/features.smoke.mjs",
    "test:run": "node test/run.smoke.mjs",
    "test:integration": "node test/integration.smoke.mjs",
    "test:dispatch": "node test/dispatch.smoke.mjs",
    "test:server": "node test/server.smoke.mjs",
    "test:heartbeat": "node test/heartbeat.smoke.mjs",
    "test:relaunch": "node test/relaunch.smoke.mjs",
    "test:loop-narrate": "node test/loop-narrate.smoke.mjs",
    "test:parallel-siblings": "node test/parallel-siblings.smoke.mjs",
    "test:concurrency": "node test/concurrency.smoke.mjs",
    "test:shaping": "npx --yes tsx test/shaping.smoke.ts",
    "prepublishOnly": "npm run build",
    "test:board-routing": "node test/board-routing.smoke.mjs",
    "test:pause": "node test/pause.smoke.mjs",
    "test:coherence": "npx --yes tsx test/coherence.smoke.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "ai",
    "agent",
    "workflow",
    "kanban",
    "orchestration",
    "verified-cards",
    "conductor",
    "claude",
    "codex"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mettafive/agent-conductor.git"
  },
  "homepage": "https://mettafive.github.io/agent-conductor",
  "bugs": {
    "url": "https://github.com/mettafive/agent-conductor/issues"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "framer-motion": "^11.15.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.5"
  }
}
